{
  "name": "alphashop-auto-selector",
  "version": "0.1.0",
  "private": true,
  "description": "Ozon product selection automation and candidate evaluator.",
  "type": "module",
  "scripts": {
    "start": "node scripts/alphashop-agent.js",
    "select": "node scripts/alphashop-agent.js",
    "ozon": "node scripts/alphashop-agent.js --platform ozon",
    "select:1688:ozon": "node scripts/select-1688-for-ozon.js --seed-file examples/ozon-1688-top5-seeds.json --max-keywords 8 --limit 8 --detail-limit 16",
    "ozon:chief": "node scripts/ozon-chief-listing-officer.js",
    "ozon:chief:audit": "node scripts/audit-1688-ozon-kb.js",
    "pipeline:1688:ozon": "node scripts/run-1688-ozon-kb-pipeline.js --seed-file examples/ozon-1688-top5-seeds.json --max-keywords 8 --limit 8 --approve-limit 5",
    "ozon:evaluate": "node scripts/ozon-evaluator.js --input examples/ozon-candidates.sample.json",
    "ozon:draft": "node scripts/ozon-listing-draft-flow.js",
    "1688:session": "node scripts/refresh-1688-session.js",
    "pipeline": "powershell -ExecutionPolicy Bypass -File launchers/run-ozon-pipeline.ps1",
    "automation:full": "node scripts/run-product-kb-pipeline.js",
    "automation:self-check": "node scripts/audit-product-kb-health.js",
    "workflow:prepare": "node scripts/prepare-product-kb.js",
    "workflow:reconcile": "node scripts/audit-product-kb-health.js",
    "kb:pipeline": "node scripts/run-product-kb-pipeline.js",
    "kb:prepare": "node scripts/prepare-product-kb.js",
    "kb:compare": "node scripts/batch-1688-compare-and-build-kb.js --all",
    "kb:audit": "node scripts/audit-product-kb-health.js",
    "kb:bootstrap-edge-session": "node scripts/bootstrap-1688-session-from-edge.js",
    "trends": "node scripts/discover-trends.js",
    "trends:dry": "node scripts/discover-trends.js --dry-run",
    "cycle": "node scripts/auto-cycle.js",
    "cycle:loop": "node scripts/auto-cycle.js --loop",
    "cycle:prune": "node scripts/auto-cycle.js --prune-only",
    "console": "node scripts/login-server.js",
    "dev": "node scripts/login-server.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "playwright": "^1.55.0",
    "sharp": "^0.34.5",
    "undici": "^7.24.7"
  }
}
